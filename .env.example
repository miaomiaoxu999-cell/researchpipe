# Copy this file to backend/.env and fill in real values.
# NEVER commit your real .env — it's in .gitignore.

# ─── External APIs ─────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
BOCHA_API_KEY=sk-...
SERPER_API_KEY=...

# 阿里百炼 (DeepSeek-V4) — LLM tool calling for /v1/agent/ask
BAILIAN_API_KEY=sk-...
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=deepseek-v4-flash
BAILIAN_ENABLE_THINKING=true

# SiliconFlow — embedding + rerank (BAAI/bge-m3 / bge-reranker-v2-m3, free tier)
SILICONFLOW_API_KEY=sk-...
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBED_MODEL=BAAI/bge-m3
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ─── ResearchPipe own keys ─────────────────────────────────────────────
RP_DEV_API_KEY=rp-dev-...
RP_DEMO_API_KEY=rp-demo-public
RP_ADMIN_KEY=rp-admin-...   # required for /v1/admin/* — generate via `openssl rand -hex 16`
RP_PORT=3725

# Allow extra CORS origins (comma-separated). Defaults already include rp.zgen.xin
# and localhost dev ports.
# RP_ALLOWED_ORIGINS=https://example.com,https://other.example.com

# ─── ResearchPipe Postgres (corpus + chunks) ────────────────────────────
# pgvector + pg_trgm. Spin up via docker:
#   docker run -d --name researchpipe_postgres -p 5433:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=researchpipe \
#     pgvector/pgvector:pg15
RP_PG_HOST=192.168.1.23
RP_PG_PORT=5433
RP_PG_NAME=researchpipe
RP_PG_USER=postgres
RP_PG_PASSWORD=change-me

# ─── qmp_data Postgres (READ-ONLY primary-market data) ──────────────────
QMP_DB_HOST=192.168.1.23
QMP_DB_PORT=5432
QMP_DB_NAME=qmp_data
QMP_DB_USER=postgres
QMP_DB_PASSWORD=change-me
