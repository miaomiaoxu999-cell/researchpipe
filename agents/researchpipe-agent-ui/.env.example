# ResearchPipe Agent UI configuration
# Copy this file to `.env.local` and fill in your key.

# Required: get from https://rp.zgen.xin/dashboard/keys (or use rp-demo for trial)
NEXT_PUBLIC_RP_API_KEY=rp-demo-public

# Backend URL — defaults to hosted ResearchPipe.
# Self-host: change to your local backend (e.g. http://localhost:3725)
NEXT_PUBLIC_RP_BACKEND_URL=https://rp.zgen.xin
